---
import '../styles/global.css';

const releaseDateIso = '2026-06-19T00:00:00-05:00';
const presaveUrl = 'https://distrokid.com/hyperfollow/banthedj/overflow';
const streamUrl = 'https://distrokid.com/hyperfollow/banthedj/overflow';
const soundcloudEmbed = 'https://w.soundcloud.com/player/?url=https%3A//soundcloud.com/banthedj/overflow&color=%230040ff&auto_play=false&hide_related=true&show_comments=false&show_user=false&show_reposts=false&show_teaser=false';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BANTHEDJ</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content="BANTHEDJ" />
    <meta property="og:description" content="Dubstep. Bass Music. Overflow." />
    <meta property="og:image" content="/images/og-image.jpg" />
    <meta property="og:url" content="https://banthedj.com" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="BANTHEDJ" />
    <meta name="twitter:description" content="Dubstep. Bass Music. Overflow." />
    <meta name="twitter:image" content="/images/banner_ban.jpg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:ital@0;1&display=swap" rel="stylesheet" />
  </head>
  <body>

    <!-- HERO -->
    <section class="hero" id="top">
      <div class="banner-wrap">
        <img src="/images/banner_ban.jpg" alt="BANTHEDJ banner" class="banner-img" />
        <div class="banner-overlay"></div>
      </div>
      <div class="hero-epk">
        <div class="hero-copy">
          <img src="/images/logo_white.jpg" alt="BANTHEDJ logo" class="hero-logo" />
          <p>
            140 / deep dubstep. Sub-bass-forward pressure, negative space, and clean dirty sound design built for club systems.
          </p>
        </div>

        <div class="bauhaus-mark" aria-hidden="true">
          <span class="mark-circle"></span>
          <span class="mark-line"></span>
          <span class="mark-square"></span>
          <span class="mark-code">01</span>
        </div>

        <div class="hero-player">
          <div class="player-label">Listen first</div>
          <iframe
            width="100%"
            height="166"
            scrolling="no"
            frameborder="no"
            allow="autoplay"
            src={soundcloudEmbed}>
          </iframe>
          <a href="#signal" class="book-btn">Join the Signal</a>
        </div>
      </div>

      <div class="motion-figure" aria-hidden="true">
        <svg viewBox="0 0 160 160" role="presentation">
          <circle class="figure-head" cx="80" cy="26" r="14"></circle>
          <path class="figure-body" d="M80 40 L80 88"></path>
          <path class="figure-arm arm-left" d="M80 54 L48 72"></path>
          <path class="figure-arm arm-right" d="M80 54 L112 66"></path>
          <path class="figure-leg leg-left" d="M80 88 L56 128"></path>
          <path class="figure-leg leg-right" d="M80 88 L108 126"></path>
          <path class="figure-prop" d="M114 64 L140 52 L148 60 L122 72 Z"></path>
          <path class="figure-shadow" d="M46 138 C62 132 98 132 118 138"></path>
        </svg>
      </div>
    </section>

    <!-- RELEASE -->
    <section class="release" data-release-date={releaseDateIso} data-presave-url={presaveUrl} data-stream-url={streamUrl}>
      <div class="release-inner">
        <div class="release-label" id="releaseState">NEW SINGLE</div>
        <div class="release-track">OVERFLOW</div>
        <div class="release-date" id="releaseCopy">Available everywhere · <span class="accent">June 19</span></div>
        <div class="countdown" id="countdown" aria-live="polite">
          <span><strong id="countDays">--</strong> days</span>
          <span><strong id="countHours">--</strong> hours</span>
          <span><strong id="countMinutes">--</strong> min</span>
        </div>
        <a href={presaveUrl} target="_blank" rel="noreferrer" class="hyperfollow-btn" id="releaseButton">Pre-save Overflow -></a>

        <div class="embed-wrap">
          <iframe
            width="100%"
            height="166"
            scrolling="no"
            frameborder="no"
            allow="autoplay"
            src={soundcloudEmbed}>
          </iframe>
        </div>
      </div>
    </section>

    <!-- BIO -->
    <section class="artist-bio">
      <div class="artist-bio-inner">
        <div class="section-kicker">BIO</div>
        <p>
          BANTHEDJ is a data engineer by day and a bass project by night, building data pipelines, apps, and whole systems with the same systems-first mindset applied to music. The project lives in the 140/deep dubstep space, with physical sub-bass pressure, negative space, and a clean dirty production philosophy that strips away excess and keeps the low end doing the work. Debut single Overflow out June 19, 2026.
        </p>
        <div class="motion-figure motion-figure--small motion-figure--lean" aria-hidden="true">
          <svg viewBox="0 0 160 160" role="presentation">
            <circle class="figure-head" cx="80" cy="26" r="14"></circle>
            <path class="figure-body" d="M80 40 L82 88"></path>
            <path class="figure-arm arm-left" d="M80 54 L60 68"></path>
            <path class="figure-arm arm-right" d="M80 54 L112 50"></path>
            <path class="figure-leg leg-left" d="M82 88 L64 124"></path>
            <path class="figure-leg leg-right" d="M82 88 L108 128"></path>
            <path class="figure-prop" d="M112 50 L136 42 L144 50 L120 58 Z"></path>
            <path class="figure-shadow" d="M54 138 C70 134 96 134 114 138"></path>
          </svg>
        </div>
      </div>
    </section>

    <!-- SIGNAL -->
    <section class="signal" id="signal">
        <div class="signal-inner">
          <div class="section-kicker">PRIVATE LIST</div>
          <h2>JOIN THE SIGNAL</h2>
          <p class="signal-copy">
            Serum presets, production notes, early drops, and occasional transmissions from BANTHEDJ.
          </p>

        <form class="signal-form" id="signalForm" data-endpoint="">
          <label class="visually-hidden" for="email">Email</label>
          <input id="email" name="email" type="email" placeholder="email address" autocomplete="email" required />

          <label class="visually-hidden" for="interest">Interest</label>
          <select id="interest" name="interest" aria-label="What should I send you?">
            <option value="serum-presets">Serum presets</option>
            <option value="unreleased-drops">Unreleased drops</option>
            <option value="production-notes">Production notes</option>
            <option value="shows">Show announcements</option>
          </select>

          <label class="visually-hidden" for="message">Message</label>
          <textarea id="message" name="message" rows="3" placeholder="drop a signal"></textarea>

          <label class="website-field" for="website">Website</label>
          <input class="website-field" id="website" name="website" type="text" tabindex="-1" autocomplete="off" />

          <button type="submit">Join the Signal</button>
          <p class="form-status" id="formStatus" role="status"></p>
        </form>
      </div>
    </section>

    <!-- HIGHLIGHTS -->
    <section class="highlights">
      <div class="highlights-inner">
        <div class="section-kicker">HIGHLIGHTS</div>
        <div class="highlight-grid">
          <article class="highlight-item">
            <span class="highlight-label">Current focus</span>
            <strong>Overflow</strong>
            <p>Debut single campaign anchored around 140 / deep dubstep and sub-bass pressure.</p>
          </article>
          <article class="highlight-item">
            <span class="highlight-label">Channels</span>
            <strong>Active everywhere</strong>
            <p>Mixcloud, SoundCloud, YouTube, Instagram, and TikTok all stay in rotation.</p>
          </article>
          <article class="highlight-item">
            <span class="highlight-label">Private access</span>
            <strong>Available on request</strong>
            <p>EPK link available upon request. Shared directly with labels, press, and promoters.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- NOTEBOOK -->
    <section class="notebook">
        <div class="notebook-inner">
        <p>
          Clean. Nasty. Dirty. Controlled damage. Bass music built like an immersive system.
        </p>
      </div>
    </section>

    <!-- GAME -->
    <section class="game-section" id="game">
      <div class="game-inner">
        <div class="game-copy">
          <div class="section-kicker">SYSTEM GAME</div>
          <h2>WANT TO PLAY A GAME?</h2>
          <p>
            A small loop about rebuilding the track. Failures reset the grid, but each reset unlocks another layer.
          </p>
          <div class="motion-figure motion-figure--small motion-figure--perch" aria-hidden="true">
            <svg viewBox="0 0 160 160" role="presentation">
              <circle class="figure-head" cx="80" cy="24" r="13"></circle>
              <path class="figure-body" d="M80 37 L78 82"></path>
              <path class="figure-arm arm-left" d="M78 52 L54 42"></path>
              <path class="figure-arm arm-right" d="M78 52 L108 64"></path>
              <path class="figure-leg leg-left" d="M78 82 L52 112"></path>
              <path class="figure-leg leg-right" d="M78 82 L104 118"></path>
              <path class="figure-prop" d="M108 64 L134 58 L140 66 L114 72 Z"></path>
              <path class="figure-shadow" d="M48 128 C64 122 96 122 112 128"></path>
            </svg>
          </div>
        </div>

        <div class="game-shell">
          <div class="game-topline">
            <span id="gameStatus">signal idle</span>
            <span>LAYERS <strong id="gameScore">0</strong></span>
          </div>
          <canvas id="noiseGame" width="520" height="360" aria-label="Filter the Noise game"></canvas>
          <div class="game-controls">
            <button type="button" data-move="left" aria-label="Move left">←</button>
            <button type="button" data-move="up" aria-label="Move up">↑</button>
            <button type="button" data-move="down" aria-label="Move down">↓</button>
            <button type="button" data-move="right" aria-label="Move right">→</button>
            <button type="button" id="gameReset">reset</button>
          </div>
        </div>
      </div>
    </section>

    <!-- LINKS -->
    <section class="links">
      <div class="links-inner">
        <div class="section-kicker">ELSEWHERE</div>
        <nav class="social-grid">
          <a href="https://soundcloud.com/banthedj/overflow" target="_blank" rel="noreferrer" class="social-link" aria-label="SoundCloud">
            <!-- SoundCloud -->
            <svg viewBox="0 0 32 32" fill="currentColor"><path d="M1.4 19.3c0 2.1 1.7 3.7 3.7 3.7s3.7-1.7 3.7-3.7V12c-.9-.5-1.9-.8-3-.8-2.7 0-4.9 2-5.3 4.6-.1.5-.1.9-.1.8 0 .9 0 1.8.5 2.7zm6.8 0V12c.8.3 1.5.8 2.1 1.5v5.8h-2.1zm3.7 0V14c.5.9.8 1.9.8 3v2.3h-.8zm2.4 0v-2.3c0-3.7 3-6.7 6.7-6.7 1 0 2 .2 2.9.6V23h-16v-.7h6.4zm10.3-8.8c-.4-.1-.8-.2-1.2-.2-3.3 0-6 2.7-6 6v2.3h8.2V12c-.3-.2-.7-.3-1-.5z"/></svg>
