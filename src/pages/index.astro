            Mixcloud
          </a>
          <a href="https://open.spotify.com/artist/3uiGjuOe1pf7gEXg27Ndqw" target="_blank" rel="noreferrer" class="social-link" aria-label="Spotify">
            <!-- Spotify -->
            <svg viewBox="0 0 32 32" fill="currentColor"><path d="M16 2C8.3 2 2 8.3 2 16s6.3 14 14 14 14-6.3 14-14S23.7 2 16 2zm6.4 20.2c-.3.4-.8.6-1.3.3-3.5-2.1-7.9-2.6-13.1-1.4-.5.1-1-.2-1.1-.7-.1-.5.2-1 .7-1.1 5.7-1.3 10.5-.7 14.5 1.6.4.3.6.8.3 1.3zm1.7-3.8c-.3.5-1 .6-1.5.3-4-2.4-10.1-3.1-14.8-1.7-.6.2-1.2-.2-1.4-.7-.2-.6.2-1.2.7-1.4 5.4-1.6 12.1-.8 16.7 1.9.5.3.7 1 .3 1.6zm.1-3.9c-4.8-2.8-12.7-3.1-17.3-1.7-.7.2-1.4-.2-1.6-.9-.2-.7.2-1.4.9-1.6 5.2-1.6 13.9-1.3 19.4 2 .6.4.8 1.2.4 1.8-.4.7-1.2.8-1.8.4z"/></svg>
            Spotify <span class="soon" id="spotifyState">Jun 19</span>
          </a>
          <a href="https://youtube.com/@banthedj" target="_blank" rel="noreferrer" class="social-link" aria-label="YouTube">
            <!-- YouTube -->
            <svg viewBox="0 0 32 32" fill="currentColor"><path d="M29.4 9.4s-.3-2.1-1.2-3c-1.2-1.2-2.5-1.2-3.1-1.3C21.6 5 16 5 16 5s-5.6 0-9.1.2c-.6.1-1.9.1-3.1 1.3-.9.9-1.2 3-1.2 3S2.3 11.7 2.3 14v2.1c0 2.3.3 4.6.3 4.6s.3 2.1 1.2 3c1.2 1.2 2.7 1.2 3.4 1.3C9.3 25.1 16 25.2 16 25.2s5.6 0 9.1-.2c.6-.1 1.9-.1 3.1-1.3.9-.9 1.2-3 1.2-3s.3-2.3.3-4.6V14c0-2.3-.3-4.6-.3-4.6zM13.2 19.8V11.4l8.4 4.2-8.4 4.2z"/></svg>
            YouTube
          </a>
          <a href="https://instagram.com/banthedj" target="_blank" rel="noreferrer" class="social-link" aria-label="Instagram">
