            Instagram
          </a>
          <a href="https://tiktok.com/@banthedj" target="_blank" rel="noreferrer" class="social-link" aria-label="TikTok">
            <!-- TikTok -->
            <svg viewBox="0 0 32 32" fill="currentColor"><path d="M27.2 7.2c-1.7-.8-3-2.2-3.7-3.9-.2-.5-.3-1-.4-1.5h-4.6v18.8c0 1.9-1.6 3.5-3.5 3.5s-3.5-1.6-3.5-3.5 1.6-3.5 3.5-3.5c.3 0 .7 0 1 .1V12.5c-.3 0-.7-.1-1-.1C9.5 12.4 5.9 16 5.9 20.5S9.5 28.6 15 28.6s9.1-3.6 9.1-9.1V13.6c1.6 1.1 3.5 1.8 5.5 1.8V11c-1 0-1.9-.7-2.4-3.8z"/></svg>
            TikTok
          </a>
        </nav>
      </div>
    </section>

    <!-- FOOTER -->
    <footer>
      <div class="footer-figure motion-figure motion-figure--footer motion-figure--float" aria-hidden="true">
        <svg viewBox="0 0 160 160" role="presentation">
          <circle class="figure-head" cx="80" cy="25" r="13"></circle>
          <path class="figure-body" d="M80 38 L80 82"></path>
          <path class="figure-arm arm-left" d="M80 50 L54 62"></path>
          <path class="figure-arm arm-right" d="M80 50 L108 44"></path>
          <path class="figure-leg leg-left" d="M80 82 L62 118"></path>
          <path class="figure-leg leg-right" d="M80 82 L102 118"></path>
          <path class="figure-prop" d="M106 42 L130 34 L140 42 L116 52 Z"></path>
          <path class="figure-shadow" d="M50 128 C64 124 94 124 110 128"></path>
        </svg>
      </div>
      <span>© 2026 BANTHEDJ</span>
      <a href="mailto:banthedj@gmail.com?subject=Management%20/%20Label%20Inquiry">Management / Label Inquiries: banthedj@gmail.com</a>
    </footer>

    <script>
      const releaseSection = document.querySelector('.release');
      const releaseDate = new Date(releaseSection?.getAttribute('data-release-date') || '');
      const presaveUrl = releaseSection?.getAttribute('data-presave-url') || '#';
      const streamUrl = releaseSection?.getAttribute('data-stream-url') || presaveUrl;

      const releaseState = document.getElementById('releaseState');
      const releaseCopy = document.getElementById('releaseCopy');
      const releaseButton = document.getElementById('releaseButton');
      const countdown = document.getElementById('countdown');
      const spotifyState = document.getElementById('spotifyState');
      const daysEl = document.getElementById('countDays');
      const hoursEl = document.getElementById('countHours');
      const minutesEl = document.getElementById('countMinutes');

      function updateReleaseState() {
        const now = new Date();
        const diff = releaseDate.getTime() - now.getTime();

        if (!Number.isFinite(diff) || diff <= 0) {
          if (releaseState) releaseState.textContent = 'OUT NOW';
          if (releaseCopy) releaseCopy.innerHTML = 'Available everywhere · <span class="accent">Out now</span>';
          if (releaseButton) {
            releaseButton.textContent = 'Stream Overflow ->';
            releaseButton.setAttribute('href', streamUrl);
          }
          if (countdown) countdown.classList.add('is-released');
          if (spotifyState) spotifyState.textContent = 'Out now';
          return;
        }

        const totalMinutes = Math.floor(diff / 60000);
        const days = Math.floor(totalMinutes / 1440);
        const hours = Math.floor((totalMinutes % 1440) / 60);
        const minutes = totalMinutes % 60;

        if (daysEl) daysEl.textContent = String(days).padStart(2, '0');
        if (hoursEl) hoursEl.textContent = String(hours).padStart(2, '0');
        if (minutesEl) minutesEl.textContent = String(minutes).padStart(2, '0');
      }

      updateReleaseState();
      window.setInterval(updateReleaseState, 30000);

      document.getElementById('printEpk')?.addEventListener('click', () => {
        window.print();
      });

      const signalForm = document.getElementById('signalForm');
      const formStatus = document.getElementById('formStatus');

      signalForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (!(signalForm instanceof HTMLFormElement)) return;
        const endpoint = signalForm.dataset.endpoint || '';
        if (!endpoint) {
          if (formStatus) formStatus.textContent = 'Signal backend coming soon.';
          return;
        }

        if (formStatus) formStatus.textContent = 'Sending...';

        const formData = new FormData(signalForm);
        const payload = Object.fromEntries(formData.entries());

        try {
          const response = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const result = await response.json().catch(() => ({}));

          if (!response.ok) {
            throw new Error(result.error || 'Could not join the signal.');
          }

          signalForm.reset();
          if (formStatus) formStatus.textContent = 'Signal received.';
        } catch (error) {
          if (formStatus) formStatus.textContent = error instanceof Error ? error.message : 'Could not join the signal.';
        }
      });

      const canvas = document.getElementById('noiseGame');
      const scoreEl = document.getElementById('gameScore');
      const statusEl = document.getElementById('gameStatus');
      const resetButton = document.getElementById('gameReset');
      const moveButtons = document.querySelectorAll('[data-move]');

      if (canvas instanceof HTMLCanvasElement) {
        const ctx = canvas.getContext('2d');
        const grid = { cols: 13, rows: 9, size: 40 };
        const blue = '#0040ff';
        const state = {
          player: { x: 1, y: 4 },
          score: 0,
          attempts: 0,
          samples: [],
          noise: [],
          tick: 0,
          message: 'signal armed',
        };

        function cellKey(cell) {
          return `${cell.x}:${cell.y}`;
        }

        function randomCell(occupied) {
          let cell;
          do {
            cell = {
              x: Math.floor(Math.random() * grid.cols),
              y: Math.floor(Math.random() * grid.rows),
            };
          } while (occupied.has(cellKey(cell)));
          occupied.add(cellKey(cell));
          return cell;
        }

        function seedGame() {
          state.player = { x: 1, y: 4 };
          state.score = 0;
          state.tick = 0;
          state.samples = [];
          state.noise = [];
          const occupied = new Set([cellKey(state.player)]);
          for (let i = 0; i < 7; i += 1) state.samples.push(randomCell(occupied));
          for (let i = 0; i < 10; i += 1) state.noise.push(randomCell(occupied));
          setGameMessage(`attempt ${state.attempts + 1}: rebuild`);
          drawGame();
        }

        function resetAfterFailure() {
          state.attempts += 1;
          state.score += 1;
          state.player = { x: 1, y: 4 };
          state.tick = 0;
          state.samples = [];
          state.noise = [];
          const occupied = new Set([cellKey(state.player)]);
          for (let i = 0; i < 7; i += 1) state.samples.push(randomCell(occupied));
          for (let i = 0; i < 8 + Math.min(state.attempts, 5); i += 1) state.noise.push(randomCell(occupied));
          setGameMessage(`failure unlocked layer ${state.score}`);
          drawGame();
        }

        function setGameMessage(message) {
          state.message = message;
          if (statusEl) statusEl.textContent = message;
          if (scoreEl) scoreEl.textContent = String(state.score);
        }

        function drawGame() {
          if (!ctx) return;
          const width = canvas.width;
          const height = canvas.height;
          ctx.clearRect(0, 0, width, height);
          ctx.fillStyle = '#000';
          ctx.fillRect(0, 0, width, height);

          ctx.strokeStyle = 'rgba(255,255,255,0.08)';
          ctx.lineWidth = 1;
          for (let x = 0; x <= grid.cols; x += 1) {
            ctx.beginPath();
            ctx.moveTo(x * grid.size, 0);
            ctx.lineTo(x * grid.size, height);
            ctx.stroke();
          }
          for (let y = 0; y <= grid.rows; y += 1) {
            ctx.beginPath();
            ctx.moveTo(0, y * grid.size);
            ctx.lineTo(width, y * grid.size);
            ctx.stroke();
          }

          state.samples.forEach((sample, index) => {
            const cx = sample.x * grid.size + grid.size / 2;
            const cy = sample.y * grid.size + grid.size / 2;
            ctx.strokeStyle = blue;
            ctx.lineWidth = 2;
            ctx.beginPath();
            ctx.arc(cx, cy, 9 + Math.sin(state.tick / 8) * 2, 0, Math.PI * 2);
            ctx.stroke();
            ctx.fillStyle = 'rgba(0,64,255,0.22)';
            ctx.fillRect(sample.x * grid.size + 13, sample.y * grid.size + 13, 14, 14);
            ctx.fillStyle = 'rgba(255,255,255,0.65)';
            ctx.font = '9px Space Mono, monospace';
            ctx.fillText(String((index + state.attempts) % 8), sample.x * grid.size + 4, sample.y * grid.size + 12);
          });

          state.noise.forEach((noise, index) => {
            const x = noise.x * grid.size;
            const y = noise.y * grid.size;
            ctx.strokeStyle = index % 2 ? 'rgba(255,255,255,0.42)' : 'rgba(255,255,255,0.24)';
            ctx.lineWidth = 2;
            ctx.beginPath();
            ctx.moveTo(x + 12, y + 12);
            ctx.lineTo(x + 28, y + 28);
            ctx.moveTo(x + 28, y + 12);
            ctx.lineTo(x + 12, y + 28);
            ctx.stroke();
          });

          const px = state.player.x * grid.size;
          const py = state.player.y * grid.size;
          ctx.fillStyle = blue;
          ctx.fillRect(px + 9, py + 9, 22, 22);
          ctx.strokeStyle = '#fff';
          ctx.lineWidth = 2;
          ctx.strokeRect(px + 9, py + 9, 22, 22);

          ctx.fillStyle = 'rgba(255,255,255,0.55)';
          ctx.font = '10px Space Mono, monospace';
          ctx.fillText(`ATTEMPT ${state.attempts + 1} // FAILURE BUILDS THE PATCH`, 12, height - 14);
        }

        function movePlayer(direction) {
          const next = { ...state.player };
          if (direction === 'left') next.x -= 1;
          if (direction === 'right') next.x += 1;
          if (direction === 'up') next.y -= 1;
          if (direction === 'down') next.y += 1;

          if (next.x < 0 || next.x >= grid.cols || next.y < 0 || next.y >= grid.rows) {
            setGameMessage('boundary clipped');
            return;
          }

          state.player = next;
          const playerKey = cellKey(state.player);
          const noiseHit = state.noise.find((noise) => cellKey(noise) === playerKey);
          if (noiseHit) {
            resetAfterFailure();
            return;
          }

          const sampleIndex = state.samples.findIndex((sample) => cellKey(sample) === playerKey);
          if (sampleIndex !== -1) {
            setGameMessage('detail noticed');
            const occupied = new Set([playerKey, ...state.noise.map(cellKey), ...state.samples.filter((_, index) => index !== sampleIndex).map(cellKey)]);
            state.samples[sampleIndex] = randomCell(occupied);
          }

          if (!noiseHit && sampleIndex === -1) {
            setGameMessage('push the boulder');
          }
          drawGame();
        }

        window.addEventListener('keydown', (event) => {
          const keyMap = {
            ArrowLeft: 'left',
            ArrowRight: 'right',
            ArrowUp: 'up',
            ArrowDown: 'down',
            a: 'left',
            d: 'right',
            w: 'up',
            s: 'down',
          };
          const direction = keyMap[event.key];
          if (!direction) return;
          event.preventDefault();
          movePlayer(direction);
        });

        moveButtons.forEach((button) => {
          button.addEventListener('click', () => {
            if (!(button instanceof HTMLButtonElement)) return;
            movePlayer(button.dataset.move || '');
          });
        });

        resetButton?.addEventListener('click', seedGame);
        seedGame();
        window.setInterval(() => {
          state.tick += 1;
          drawGame();
        }, 120);
      }
    </script>

  </body>
</html>
