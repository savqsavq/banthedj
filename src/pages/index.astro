---
import '../styles/global.css';

const socials = [
  { name: 'SoundCloud', url: 'https://soundcloud.com/banthedj', icon: 'sc' },
  { name: 'Spotify', url: 'https://spotify.com', icon: 'sp' },
  { name: 'YouTube', url: 'https://youtube.com/@banthedj', icon: 'yt' },
  { name: 'Instagram', url: 'https://instagram.com/banthedj', icon: 'ig' },
  { name: 'TikTok', url: 'https://tiktok.com/@banthedj', icon: 'tt' },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BANTHEDJ</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:ital@0;1&display=swap" rel="stylesheet" />
  </head>
  <body>

    <!-- HERO -->
    <section class="hero">
      <div class="banner-wrap">
        <img src="/images/banner_ban.jpg" alt="BANTHEDJ banner" class="banner-img" />
        <div class="banner-overlay"></div>
      </div>
      <div class="hero-title-wrap">
        <h1 class="hero-title">BANTHEDJ</h1>
      </div>
    </section>

    <!-- RELEASE -->
    <section class="release">
      <div class="release-inner">
        <div class="release-label">NEW SINGLE</div>
        <div class="release-track">OVERFLOW</div>
        <div class="release-date">Available everywhere · <span class="accent">June 18</span></div>

        <div class="embed-wrap">
          <iframe
            width="100%"
            height="166"
            scrolling="no"
            frameborder="no"
            allow="autoplay"
            src="https://w.soundcloud.com/player/?url=https%3A//soundcloud.com/banthedj/overflow&color=%230040ff&auto_play=false&hide_related=true&show_comments=false&show_user=false&show_reposts=false&show_teaser=false">
          </iframe>
        </div>
      </div>
    </section>

    <!-- LINKS -->
    <section class="links">
      <div class="links-inner">
        <nav class="social-grid">
          <a href="https://soundcloud.com/banthedj/overflow" target="_blank" class="social-link" aria-label="SoundCloud">
            <!-- SoundCloud -->
            <svg viewBox="0 0 32 32" fill="currentColor"><path d="M1.4 19.3c0 2.1 1.7 3.7 3.7 3.7s3.7-1.7 3.7-3.7V12c-.9-.5-1.9-.8-3-.8-2.7 0-4.9 2-5.3 4.6-.1.5-.1.9-.1.8 0 .9 0 1.8.5 2.7zm6.8 0V12c.8.3 1.5.8 2.1 1.5v5.8h-2.1zm3.7 0V14c.5.9.8 1.9.8 3v2.3h-.8zm2.4 0v-2.3c0-3.7 3-6.7 6.7-6.7 1 0 2 .2 2.9.6V23h-16v-.7h6.4zm10.3-8.8c-.4-.1-.8-.2-1.2-.2-3.3 0-6 2.7-6 6v2.3h8.2V12c-.3-.2-.7-.3-1-.5z"/></svg>
            SoundCloud
          </a>
          <a href="https://open.spotify.com" target="_blank" class="social-link" aria-label="Spotify">
            <!-- Spotify -->
            <svg viewBox="0 0 32 32" fill="currentColor"><path d="M16 2C8.3 2 2 8.3 2 16s6.3 14 14 14 14-6.3 14-14S23.7 2 16 2zm6.4 20.2c-.3.4-.8.6-1.3.3-3.5-2.1-7.9-2.6-13.1-1.4-.5.1-1-.2-1.1-.7-.1-.5.2-1 .7-1.1 5.7-1.3 10.5-.7 14.5 1.6.4.3.6.8.3 1.3zm1.7-3.8c-.3.5-1 .6-1.5.3-4-2.4-10.1-3.1-14.8-1.7-.6.2-1.2-.2-1.4-.7-.2-.6.2-1.2.7-1.4 5.4-1.6 12.1-.8 16.7 1.9.5.3.7 1 .3 1.6zm.1-3.9c-4.8-2.8-12.7-3.1-17.3-1.7-.7.2-1.4-.2-1.6-.9-.2-.7.2-1.4.9-1.6 5.2-1.6 13.9-1.3 19.4 2 .6.4.8 1.2.4 1.8-.4.7-1.2.8-1.8.4z"/></svg>
            Spotify <span class="soon">Jun 18</span>
          </a>
          <a href="https://youtube.com/@banthedj" target="_blank" class="social-link" aria-label="YouTube">
            <!-- YouTube -->
            <svg viewBox="0 0 32 32" fill="currentColor"><path d="M29.4 9.4s-.3-2.1-1.2-3c-1.2-1.2-2.5-1.2-3.1-1.3C21.6 5 16 5 16 5s-5.6 0-9.1.2c-.6.1-1.9.1-3.1 1.3-.9.9-1.2 3-1.2 3S2.3 11.7 2.3 14v2.1c0 2.3.3 4.6.3 4.6s.3 2.1 1.2 3c1.2 1.2 2.7 1.2 3.4 1.3C9.3 25.1 16 25.2 16 25.2s5.6 0 9.1-.2c.6-.1 1.9-.1 3.1-1.3.9-.9 1.2-3 1.2-3s.3-2.3.3-4.6V14c0-2.3-.3-4.6-.3-4.6zM13.2 19.8V11.4l8.4 4.2-8.4 4.2z"/></svg>
            YouTube
          </a>
          <a href="https://instagram.com/banthedj" target="_blank" class="social-link" aria-label="Instagram">
            <!-- Instagram -->
            <svg viewBox="0 0 32 32" fill="currentColor"><path d="M16 2.9c4.4 0 4.9 0 6.6.1 1.6.1 2.5.3 3 .6.8.3 1.3.7 1.9 1.3.6.6 1 1.1 1.3 1.9.2.6.5 1.4.6 3 .1 1.7.1 2.2.1 6.6s0 4.9-.1 6.6c-.1 1.6-.3 2.5-.6 3-.3.8-.7 1.3-1.3 1.9-.6.6-1.1 1-1.9 1.3-.6.2-1.4.5-3 .6-1.7.1-2.2.1-6.6.1s-4.9 0-6.6-.1c-1.6-.1-2.5-.3-3-.6-.8-.3-1.3-.7-1.9-1.3-.6-.6-1-1.1-1.3-1.9-.2-.6-.5-1.4-.6-3C2.9 20.9 2.9 20.4 2.9 16s0-4.9.1-6.6c.1-1.6.3-2.5.6-3 .3-.8.7-1.3 1.3-1.9.6-.6 1.1-1 1.9-1.3.6-.2 1.4-.5 3-.6 1.7-.1 2.2-.1 6.6-.1zm0-2.9c-4.5 0-5 0-6.8.1C7.4.1 6.1.4 5 .9 3.9 1.4 2.9 2 2 2.9 1.1 3.8.5 4.8 0 5.9-.4 7 .1 8.3 0 10.1 0 11.9 0 12.5 0 16c0 3.5 0 4.1.1 5.9.1 1.8.4 3.1.9 4.2.5 1.1 1.1 2.1 2 3 .9.9 1.9 1.5 3 2 1.1.4 2.4.8 4.2.9 1.8.1 2.4.1 5.9.1s4.1 0 5.9-.1c1.8-.1 3.1-.4 4.2-.9 1.1-.5 2.1-1.1 3-2 .9-.9 1.5-1.9 2-3 .4-1.1.8-2.4.9-4.2.1-1.8.1-2.4.1-5.9s0-4.1-.1-5.9c-.1-1.8-.4-3.1-.9-4.2-.5-1.1-1.1-2.1-2-3-.9-.9-1.9-1.5-3-2C22.9.4 21.6.1 19.8 0 18.1 0 17.5 0 16 0zm0 7.8c-4.5 0-8.2 3.7-8.2 8.2s3.7 8.2 8.2 8.2 8.2-3.7 8.2-8.2-3.7-8.2-8.2-8.2zm0 13.5c-2.9 0-5.3-2.4-5.3-5.3s2.4-5.3 5.3-5.3 5.3 2.4 5.3 5.3-2.4 5.3-5.3 5.3zm10.4-13.8c0 1.1-.9 1.9-1.9 1.9-1.1 0-1.9-.9-1.9-1.9 0-1.1.9-1.9 1.9-1.9 1.1 0 1.9.8 1.9 1.9z"/></svg>
            Instagram
          </a>
          <a href="https://tiktok.com/@banthedj" target="_blank" class="social-link" aria-label="TikTok">
            <!-- TikTok -->
            <svg viewBox="0 0 32 32" fill="currentColor"><path d="M27.2 7.2c-1.7-.8-3-2.2-3.7-3.9-.2-.5-.3-1-.4-1.5h-4.6v18.8c0 1.9-1.6 3.5-3.5 3.5s-3.5-1.6-3.5-3.5 1.6-3.5 3.5-3.5c.3 0 .7 0 1 .1V12.5c-.3 0-.7-.1-1-.1C9.5 12.4 5.9 16 5.9 20.5S9.5 28.6 15 28.6s9.1-3.6 9.1-9.1V13.6c1.6 1.1 3.5 1.8 5.5 1.8V11c-1 0-1.9-.7-2.4-3.8z"/></svg>
            TikTok
          </a>
        </nav>
      </div>
    </section>

    <!-- FOOTER -->
    <footer>
      <span>© 2026 BANTHEDJ</span>
      <a href="mailto:banthedj@gmail.com">banthedj@gmail.com</a>
    </footer>

  </body>
</html>