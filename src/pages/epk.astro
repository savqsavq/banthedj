---
import '../styles/global.css';

const soundcloudEmbed = 'https://w.soundcloud.com/player/?url=https%3A//soundcloud.com/banthedj/overflow&color=%231f1abc&auto_play=false&hide_related=true&show_comments=false&show_user=false&show_reposts=false&show_teaser=false';
const cloudflareAnalyticsToken = import.meta.env.PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN || 'ce06ce76509044c58a21f86aa8bfc8e1';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BANTHEDJ EPK</title>
    <meta name="description" content="Private EPK for BANTHEDJ." />
    <meta name="robots" content="noindex,nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content="BANTHEDJ EPK" />
    <meta property="og:description" content="Private EPK for labels, press, and promoters." />
    <meta property="og:image" content="/images/og-image.jpg" />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:ital@0;1&display=swap" rel="stylesheet" />
  </head>
  <body>
    <section class="hero" id="top">
      <div class="banner-wrap">
        <img src="/images/banner_ban.jpg" alt="BANTHEDJ banner" class="banner-img" />
        <div class="banner-overlay"></div>
      </div>
      <div class="hero-epk">
        <div class="hero-copy">
          <img src="/images/logo_white.jpg" alt="BANTHEDJ logo" class="hero-logo" />
          <div class="section-kicker">PRIVATE EPK</div>
          <h1 class="hero-title">BANTHEDJ EPK</h1>
          <p>
            140 / deep dubstep. Sub-bass-forward pressure, negative space, and clean dirty sound design built for club systems.
          </p>
        </div>

        <div class="hero-player">
          <div class="player-label">Listen first</div>
          <iframe
            width="100%"
            height="166"
            scrolling="no"
            frameborder="no"
            allow="autoplay"
            src={soundcloudEmbed}>
          </iframe>
          <a href="mailto:banthedj@gmail.com?subject=Booking%20BANTHEDJ" class="book-btn">Book banthedj</a>
        </div>
      </div>
    </section>

    <section class="epk" id="bio">
      <div class="epk-inner">
        <div class="section-kicker">BIO</div>
        <div class="bio-block">
          <p>
            BANTHEDJ is a data engineer by day and a bass project by night, building data pipelines, apps, and whole systems with the same systems-first mindset applied to music. The project lives in the 140/deep dubstep space, with physical sub-bass pressure, negative space, and a clean dirty production philosophy that strips away excess and keeps the low end doing the work. Debut single Overflow out June 19, 2026.
          </p>
        </div>

        <div class="system-strip" aria-label="BANTHEDJ system tags">
          <span>signal.clean()</span>
          <span>noise.filter()</span>
          <span>sub_bass.render()</span>
          <span>club_system.compile()</span>
        </div>

        <div class="press-grid">
          <figure>
            <img src="/images/current_press.png" alt="BANTHEDJ current press image" />
          </figure>
        </div>

        <div class="epk-panels">
          <div class="rider-panel">
            <div class="section-kicker">TECH RIDER</div>
            <ul>
              <li>2x Pioneer CDJ-3000s, CDJ-2000NXS2s, or equivalent club media players.</li>
              <li>1x Pioneer DJM-A9, DJM-900NXS2, or Xone:96 mixer.</li>
              <li>2x dedicated booth monitors with independent booth volume control.</li>
              <li>USB-ready setup, stable booth power, and direct stage manager / sound engineer contact.</li>
            </ul>
          </div>

          <div class="contact-panel">
            <div class="section-kicker">ASSETS</div>
            <a href="mailto:banthedj@gmail.com?subject=Press%20Assets%20for%20BANTHEDJ" class="secondary-link">Request press assets</a>
            <a href="/images/current_press.png" target="_blank" rel="noreferrer" class="secondary-link">Open current press image</a>
            <a href="/images/logo_white.jpg" target="_blank" rel="noreferrer" class="secondary-link">Open logo file</a>
            <button type="button" class="secondary-link print-button" id="printEpk">Download / print EPK as PDF</button>
            <p>Private demo links and additional materials are shared directly on request.</p>
          </div>
        </div>
      </div>
    </section>

    <footer>
      <span>© 2026 BANTHEDJ</span>
      <a href="mailto:banthedj@gmail.com?subject=Management%20/%20Label%20Inquiry">Management / Label Inquiries: banthedj@gmail.com</a>
    </footer>

    <script>
      const printButton = document.getElementById('printEpk');
      printButton?.addEventListener('click', () => window.print());
    </script>
    {cloudflareAnalyticsToken && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={JSON.stringify({ token: cloudflareAnalyticsToken })}
      />
    )}
  </body>
</html>
